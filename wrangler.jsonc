{
  "name": "portfolio",
  "compatibility_date": "2026-04-01",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "brandonma.dev",
      "zone_name": "brandonma.dev",
      "custom_domain": true,
    },
  ],
  "preview_urls": false,
}
